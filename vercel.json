{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "env": {
    "DATABASE_URL": "sqlite+pysqlite:////tmp/workflowgym_vercel.db",
    "AUTO_SEED_DEMO": "true"
  }
}
